# ============================================
# CONFIGURACIÓN DEL SERVIDOR MINECRAFT
# ============================================

# Nombre del servidor
MC_SERVER_NAME=Mi Servidor Forge

# Versión de Minecraft (ej: 1.20.1, 1.19.2, etc.)
MC_VERSION=1.20.1

# Versión de Forge (descarga desde forge.net)
FORGE_VERSION=47.2.0

# Puerto del servidor Minecraft
MC_PORT=25565

# Puerto RCON (acceso remoto)
MC_RCON_PORT=25575

# Contraseña RCON
RCON_PASSWORD=tu_contraseña_rcon_segura

# Máximo de jugadores
MAX_PLAYERS=20

# Dificultad (peaceful, easy, normal, hard)
DIFFICULTY=normal

# Modo de juego (survival, creative, adventure, spectator)
GAMEMODE=survival

# ============================================
# CONFIGURACIÓN DE JAVA
# ============================================

# Memoria máxima (XMX)
JAVA_XMX=6G

# Memoria mínima (XMS)
JAVA_XMS=2G

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================

# Contraseña root de MySQL
DB_ROOT_PASSWORD=root_password_muy_segura

# Nombre de la base de datos
DB_NAME=minecraft_db

# Usuario de base de datos
DB_USER=minecraft_user

# Contraseña del usuario de base de datos
DB_PASSWORD=user_password_muy_segura

# ============================================
# CONFIGURACIÓN DEL PANEL WEB
# ============================================

# Entorno de Flask (development, production)
FLASK_ENV=production

# Puerto del panel web (se expone en 8080)
PANEL_PORT=5000

# ============================================
# CONFIGURACIÓN DE PLAYIT.GG (Tunneling)
# ============================================

# Habilitar playit.gg para exponer servidor en internet
ENABLE_PLAYIT=false

# Versión de playit.gg (descarga desde builds.playit.gg)
PLAYIT_VERSION=0.17.1
